Options -Indexes

RewriteEngine On

# ── Forzar HTTPS ────────────────────────────────────────────────────
# Redirige a HTTPS solo si aun NO lo es. Contempla el proxy SSL de Hostinger
# (X-Forwarded-Proto) y el puerto 443 para no entrar en bucle de redireccion.
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{SERVER_PORT} !=443
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── Cabeceras de seguridad ──────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # HSTS: el navegador fuerza HTTPS por 1 anio (solo se aplica sobre HTTPS)
    Header always set Strict-Transport-Security "max-age=31536000"
</IfModule>

# ── Defensa en profundidad ──────────────────────────────────────────
# El rewrite de mas abajo ya envia todo a public/ (los archivos internos
# dan 404), pero estas reglas niegan el acceso de forma EXPLICITA por si
# el rewrite cambiara o se intentara evadir.

# Archivos/carpetas ocultos (.git, .env, etc.) salvo .well-known (SSL/ACME)
RewriteRule (^|/)\.(?!well-known) - [F,L]

# Carpetas internas del proyecto (no contienen assets publicos)
RewriteRule ^(app|core|config|database|resources|storage)(/|$) - [F,L]

# Extensiones sensibles (volcados, docs, logs, configs)
RewriteRule \.(sql|md|log|lock|sh|ya?ml|dist)$ - [F,L]

# ── Front controller: todo lo demas pasa por public/ ────────────────
RewriteRule ^$ public/ [L]
RewriteRule (.*) public/$1 [L]
