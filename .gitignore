# Dependencias
/vendor/

# Credenciales de produccion: viven fuera del repo (~/siga_secrets/database.php).
# config/database.php ahora es solo un cargador sin secretos, por eso SI se versiona.

# Volcados completos de la base de datos (datos personales de menores, no versionar)
/database/backup_*.sql

# Storage generado
/storage/logs/*.log
/storage/uploads/*
/storage/pdfs/*
# Firma/sello del Director EBR en local (datos del entorno; en prod viven en
# ~/siga_uploads/firmas). Se sirven por FirmaController, no se versionan.
/storage/firmas/*.png
# Temporales EFIMEROS del modulo Actas SIAGIE (xlsx subido entre previsualizar y
# confirmar; en prod viven en ~/siga_uploads/siagie_tmp). Nunca se versionan.
/storage/tmp/

# Archivos de sistema
.DS_Store
Thumbs.db
desktop.ini
nul
-

# IDE
.idea/
.vscode/settings.json
*.swp
*.swo

# Config local de Claude Code (permisos por maquina, no versionar)
.claude/settings.local.json

# PHP
*.cache

# Scripts temporales de uso único (no commitear)
hash.php
import_matriculas.php

# Logs de chat / notas (no versionar ni desplegar)
/CHAT_CLAUDE_CODE_*.txt

# Mantener carpetas vacías con .gitkeep
!storage/logs/.gitkeep
!storage/uploads/.gitkeep
!storage/pdfs/.gitkeep

# Node
node_modules/
package-lock.json

# SIAGIE — archivos con datos de estudiantes, respaldos y reportes (nunca versionar)
scripts/siagie/modelos/
scripts/siagie/backup/
scripts/siagie/**/*.xlsx
scripts/siagie/**/*_reporte_*.txt
