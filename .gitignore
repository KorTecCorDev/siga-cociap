# Dependencias
/vendor/

# Configuración local (contiene credenciales)
/config/database.php

# Volcados completos de la base de datos (datos personales de menores, no versionar)
/database/backup_*.sql

# Storage generado
/storage/logs/*.log
/storage/uploads/*
/storage/pdfs/*

# Archivos de sistema
.DS_Store
Thumbs.db
desktop.ini
nul
-

# IDE
.idea/
.vscode/settings.json
*.swp
*.swo

# PHP
*.cache

# Scripts temporales de uso único (no commitear)
hash.php
import_matriculas.php

# Mantener carpetas vacías con .gitkeep
!storage/logs/.gitkeep
!storage/uploads/.gitkeep
!storage/pdfs/.gitkeep

# Imágenes de firma/sello del Director EBR (datos del entorno, no del repo)
/public/assets/img/firmas/*.png
!/public/assets/img/firmas/.gitkeep

# Node
node_modules/
package-lock.json
